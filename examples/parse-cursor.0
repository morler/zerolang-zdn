use std.parse

pub fn main(world: World) -> Void raises {
    let digit: Bool = std.parse.isAsciiDigit("7")
    let ident: Bool = std.parse.isIdentifierStart("_")
    let digits: usize = std.parse.scanDigits("123abc")
    let port: Maybe<u16> = std.parse.parseU16("8080")
    if digit && ident && digits == 3 && port.has && port.value == 8080 {
        check world.out.write("parse primitives ok\n")
    }
}
