export c fn main() -> u8 {
    var storage: [4]u8 = [0, 0, 0, 0]
    var buf: Vec = std.mem.vec(storage)
    let first: Bool = std.mem.vecPush(&mut buf, 65_u8)
    let second: Bool = std.mem.vecPush(&mut buf, 66_u8)
    if first {
        if second {
            if std.mem.vecLen(&buf) == 2 {
                if std.mem.vecCapacity(&buf) == 4 {
                    return storage[1]
                }
            }
        }
    }
    return 0_u8
}
