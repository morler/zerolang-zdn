use std.codec

use std.parse

use std.time

use helpers

use types

pub fn main(world: World) -> Void raises {
    defer cleanup()
    let current: Status = status()
    let result: Result = Result.ok
    let word: u32 = std.codec.readU32("abcd")
    let digits: usize = std.parse.scanDigits("123abc")
    let duration: Duration = std.time.add(std.time.ms(5), std.time.seconds(1))
    if digits == 3 && word > 0 && std.time.asMsFloor(duration) > 0 {
        check world.out.write("systems package\n")
    }
}
