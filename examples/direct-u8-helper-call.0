fn is_letter_a(code: u8) -> Bool {
    if code == 65_u8 {
        return true
    }
    return false
}

export c fn main() -> i32 {
    let bytes: [2]u8 = [65_u8, 66_u8]
    var i: usize = 0
    var score: i32 = 0
    while i < 2 {
        if is_letter_a(bytes[i]) {
            score = score + 1
        }
        i = i + 1
    }
    return score
}
