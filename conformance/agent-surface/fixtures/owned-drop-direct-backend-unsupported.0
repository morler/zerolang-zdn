type Tracked {
    value: i32,
    fn drop(self: mutref<Self>) -> Void {
        self.value = 0
    }
}

pub fn main(world: World) -> Void raises {
    let tracked: owned<Tracked> = Tracked { value: 42 }
    if tracked.value == 42 {
        check world.out.write("owned drop backend unsupported current ok\n")
    }
}
