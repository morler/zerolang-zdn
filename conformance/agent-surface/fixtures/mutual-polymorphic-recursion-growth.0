fn left<T: Type>(value: T) -> Void {
    let nested: Maybe<T> = null
    right<Maybe<T>>(nested)
}

fn right<T: Type>(value: T) -> Void {
    let nested: Maybe<T> = null
    left<Maybe<T>>(nested)
}

pub fn main(world: World) -> Void raises {
    left<i32>(1)
    check world.out.write("mutual polymorphic recursion ok\n")
}
