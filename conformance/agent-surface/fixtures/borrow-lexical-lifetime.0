type Data {
    value: i32,
}

fn update(target: mutref<Data>) -> Void {
    target.value = target.value + 1
}

pub fn main(world: World) -> Void raises {
    var data: Data = Data { value: 0 }
    let shared: ref<Data> = &data
    let observed: i32 = shared.value
    update(&mut data)
    if observed == 0 {
        check world.out.write("borrow lexical lifetime current ok\n")
    }
}
