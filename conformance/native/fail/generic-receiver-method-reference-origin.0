type Box<T: Type> {
    items: [1]T,
    fn get(self: ref<Self>) -> Maybe<T> {
        return std.mem.get(self.items, 0)
    }
}

pub fn main() -> Void {
    var x: i32 = 1
    let y: i32 = 2
    var box: Box<ref<i32>> = Box { items: [&x] }
    let maybe: Maybe<ref<i32>> = box.get()
    if !maybe.has {
        return
    }
    let current: ref<i32> = maybe.value
    box.items = [&y]
    x = 2
}
