type Box {
    value: ref<i32>,
}

enum Mode {
    keep,
    replace,
}

pub fn main(mode: Mode) -> Void {
    var x: i32 = 1
    let y: i32 = 2
    var box: Box = Box { value: &x }
    match mode {
        keep {
        }
        replace {
            box = Box { value: &y }
        }
    }
    x = 3
}
