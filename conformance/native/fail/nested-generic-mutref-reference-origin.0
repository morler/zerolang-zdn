type Cell<T: Type> {
    value: ref<T>,
}

fn replace<T: Type>(cell: mutref<Cell<T>>, next: ref<T>) -> Void {
    cell.value = next
}

fn wrapper<T: Type>(cell: mutref<Cell<T>>, next: ref<T>) -> Void {
    replace<T>(cell, next)
}

pub fn main() -> Void {
    var old: i32 = 1
    var next: i32 = 2
    var cell: Cell<i32> = Cell { value: &old }
    wrapper<i32>(&mut cell, &next)
    next = 3
}
