export c fn main() -> i32 {
    let net: Net = std.net.host()
    let client: HttpClient = std.http.client(net)
    let request: Span<u8> = std.mem.span("GET http://example.invalid\n\n")
    var response: [64]u8 = [0_u8; 64]
    let result: i32 = std.http.fetch(client, request, response, 1000)
    if std.http.resultOk(result) {
        return 1
    }
    return 0
}
