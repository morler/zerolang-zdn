type File {
    fd: i32,
}

fn consume(file: owned<File>) -> Void {
}

fn unwrapTwice(maybe: Maybe<owned<File>>) -> Void raises {
    let first: owned<File> = check maybe
    consume(first)
    let second: owned<File> = check maybe
    consume(second)
}

pub fn main() -> Void raises {
    let maybe: Maybe<owned<File>> = null
    unwrapTwice(maybe)
}
