type Box {
    a: ref<i32>,
    b: ref<i32>,
    fn replaceA(self: mutref<Self>, next: ref<i32>) -> Box {
        self.a = next
        return Box { a: next, b: self.b }
    }
}

pub fn main() -> Void {
    var x: i32 = 1
    let y: i32 = 2
    let z: i32 = 3
    var box: Box = Box { a: &z, b: &x }
    let copy: Box = box.replaceA(&y)
    box.b = &y
    x = 4
}
