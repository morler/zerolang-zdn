type Holder {
    value: ref<i32>,
}

fn copyStored(dst: mutref<Holder>, src: mutref<Holder>) -> Void {
    dst.value = src.value
}

pub fn main() -> Void {
    var x: i32 = 1
    let y: i32 = 2
    let z: i32 = 3
    var src: Holder = Holder { value: &x }
    var dst: Holder = Holder { value: &y }
    copyStored(&mut dst, &mut src)
    dst.value = &z
    x = 4
}
