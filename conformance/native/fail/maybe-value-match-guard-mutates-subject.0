type Holder {
    value: Maybe<u8>,
}

fn clear(holder: mutref<Holder>) -> Bool {
    holder.value = null
    return true
}

pub fn main() -> Void {
    let bytes: [1]u8 = [1]
    var holder: Holder = Holder { value: std.mem.get(bytes, 0) }
    match holder.value.has {
        true if clear(&mut holder) {
            let byte: u8 = holder.value.value
        }
        true {
        }
        false {
        }
    }
}
