type Holder {
    value: ref<i32>,
    fn store(self: mutref<Self>, next: ref<i32>) -> Void {
        self.value = next
    }
}

interface Storer<T: Type> {
    fn store(self: mutref<T>, next: ref<i32>) -> Void
}

fn through<T: Storer<T>>(holder: mutref<T>, next: ref<i32>) -> Void {
    T.store(holder, next)
}

pub fn main() -> Void {
    var old: i32 = 1
    var next: i32 = 2
    var holder: Holder = Holder { value: &old }
    through<Holder>(&mut holder, &next)
    next = 3
}
