fn identity<T: Type>(value: T) -> T {
    return value
}

fn first<T: Type>(left: T, right: T) -> T {
    return left
}

pub fn main(world: World) -> Void raises {
    let a: i32 = identity<i32>(41)
    let b: u8 = identity(7_u8)
    let c: i32 = first(9, 12)
    if a == 41 && b == 7_u8 && c == 9 {
        check world.out.write("generic function ok\n")
    } else {
        check world.out.write("generic function broke\n")
    }
}
