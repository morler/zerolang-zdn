type Box {
    value: ref<i32>,
}

fn get(box: ref<Box>) -> ref<i32> {
    return box.value
}

fn getMut(box: mutref<Box>) -> ref<i32> {
    return box.value
}

pub fn main() -> Void {
    var x: i32 = 1
    let y: i32 = 2
    let z: i32 = 3
    var box: Box = Box { value: &x }
    let current: ref<i32> = get(&box)
    box.value = &y
    let other: ref<i32> = getMut(&mut box)
    box.value = &z
}
