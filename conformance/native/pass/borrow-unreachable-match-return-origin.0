enum Mode {
    left,
    alsoLeft,
}

fn choose(mode: Mode, left: ref<i32>, right: ref<i32>) -> ref<i32> {
    match mode {
        left {
            return left
        }
        alsoLeft {
            return left
        }
    }
    return right
}

pub fn main(mode: Mode) -> Void {
    let x: i32 = 1
    var y: i32 = 2
    let current: ref<i32> = choose(mode, &x, &y)
    y = 3
}
