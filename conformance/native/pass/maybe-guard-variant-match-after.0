choice Flag {
    yes,
    no,
}

fn read(flag: Flag) -> u8 {
    let input: [1]u8 = [1]
    let value: Maybe<u8> = std.mem.get(input, 0)
    match flag {
        .yes if value.has {
        }
        .yes {
            return 0_u8
        }
        .no {
            return 0_u8
        }
    }
    return value.value
}

pub fn main() -> Void {
    let byte: u8 = read(Flag.yes)
}
