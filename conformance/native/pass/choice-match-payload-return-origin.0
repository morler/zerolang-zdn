choice Slot {
    some: ref<i32>,
    none,
}

fn get(slot: Slot, fallback: ref<i32>) -> ref<i32> {
    match slot {
        .some(borrowed) {
            return borrowed
        }
        none {
            return fallback
        }
    }
}

pub fn main() -> Void {
    let value: i32 = 1
    let slot: Slot = Slot.some(&value)
    let _borrowed: ref<i32> = get(slot, &value)
}
