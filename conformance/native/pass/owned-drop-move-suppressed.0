type DropProbe {
    marker: MutSpan<u8>,
    fn drop(self: mutref<Self>) -> Void {
        self.marker[0] = 1
    }
}

fn consume(probe: owned<DropProbe>) -> Void {
}

pub fn main(world: World) -> Void raises {
    var marker: [1]u8 = [0]
    if true {
        let probe: owned<DropProbe> = DropProbe { marker: marker }
        consume(probe)
    }
    if marker[0] == 0 {
        check world.out.write("owned drop move suppressed ok\n")
    } else {
        check world.out.write("owned drop move suppressed failed\n")
    }
}
