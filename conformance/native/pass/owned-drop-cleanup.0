type DropProbe {
    marker: MutSpan<u8>,
    fn drop(self: mutref<Self>) -> Void {
        self.marker[0] = 1
    }
}

pub fn main(world: World) -> Void raises {
    var marker: [1]u8 = [0]
    if true {
        let probe: owned<DropProbe> = DropProbe { marker: marker }
    }
    if marker[0] == 1 {
        check world.out.write("owned drop cleanup ok\n")
    } else {
        check world.out.write("owned drop cleanup failed\n")
    }
}
