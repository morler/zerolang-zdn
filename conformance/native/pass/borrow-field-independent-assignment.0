type Pair {
    left: i32,
    right: i32,
}

pub fn main() -> Void {
    var pair: Pair = Pair { left: 1, right: 2 }
    let left: ref<i32> = &pair.left
    pair.right = 3
    var second: Pair = Pair { left: 4, right: 5 }
    let second_left: mutref<i32> = &mut second.left
    second.right = 6
    let second_right: mutref<i32> = &mut second.right
}
