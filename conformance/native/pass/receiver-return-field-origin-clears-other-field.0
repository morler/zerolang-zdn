type Box {
    value: ref<i32>,
    count: i32,
    fn countRef(self: ref<Self>) -> ref<i32> {
        return &self.count
    }
}

pub fn main() -> Void {
    var x: i32 = 1
    let y: i32 = 2
    var box: Box = Box { value: &x, count: 0 }
    let current: ref<i32> = box.countRef()
    box.value = &y
    x = 3
}
