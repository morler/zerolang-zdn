extern type CPoint {
    x: i32,
    y: i32,
}

export c fn zero_add(a: i32, b: i32) -> i32 {
    return a + b
}

pub fn main(world: World) -> Void raises {
    let point: CPoint = CPoint { x: 2, y: 3 }
    if zero_add(point.x, point.y) == 5 {
        check world.out.write("c abi export ok\n")
    }
}
