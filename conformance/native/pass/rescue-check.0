fn fail_value() -> i32 raises [Missing] {
    raise Missing
}

pub fn main(world: World) -> Void raises {
    var small: [4]u8 = [0, 0, 0, 0]
    let a: String = rescue std.path.join(small, "too", "long") err "fallback"
    let b: i32 = rescue fail_value() err 4
    if std.mem.eql(a, "fallback") && b == 4 {
        check world.out.write("rescue ok\n")
    }
}
