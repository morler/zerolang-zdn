const cap: usize = 3

fn head<T: Type, static N: usize>(items: ref<[N]T>) -> T {
    return items[0]
}

fn forward<T: Type, static N: usize>(items: ref<[N]T>) -> T {
    return head(items)
}

pub fn main() -> Void {
    let values: [cap]i32 = [7, 8, 9]
    let first: i32 = forward(&values)
    expect (first == 7)
}
