type Gate<static enabledFlag: Bool, static selectedMode: Mode> {
    value: i32,
}

enum Mode: u8 {
    fast,
    tiny,
}

fn readGate<static enabledFlag: Bool, static selectedMode: Mode>(gate: ref<Gate<enabledFlag, selectedMode>>) -> i32 {
    return gate.value
}

pub fn main(world: World) -> Void raises {
    let gate: Gate<true, Mode.fast> = Gate { value: 1 }
    let _value: i32 = readGate<false, Mode.fast>(&gate)
    check world.out.write("bad static bool enum mismatch\n")
}
