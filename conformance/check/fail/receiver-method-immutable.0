type FixedVec<T: Type, static N: usize> {
    len: usize,
    items: [N]T,
    fn push(self: mutref<Self>, value: T) -> Void raises [Full] {
        if self.len == N {
            raise Full
        }
        self.items[self.len] = value
        self.len = self.len + 1
    }
}

pub fn main() -> Void raises {
    let vec: FixedVec<u8, 4> = FixedVec { len: 0, items: [0, 0, 0, 0] }
    check vec.push(1)
}
