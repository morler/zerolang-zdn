fn isPrime(n: u32) -> Bool {
    if n < 2 {
        return false
    }
    var divisor: u32 = 2
    while divisor * divisor <= n {
        if n % divisor == 0 {
            return false
        }
        divisor = divisor + 1
    }
    return true
}

pub fn main(world: World) -> Void raises {
    if isPrime(2) && isPrime(29) && !isPrime(30) {
        check world.out.write("prime ok\n")
    }
}
