pub fn main(world: World) -> Void raises {
    var prime: [31]Bool = [true; 31]
    prime[0] = false
    prime[1] = false
    var p: usize = 2
    while p * p <= 30 {
        if prime[p] {
            var n: usize = p * p
            while n <= 30 {
                prime[n] = false
                n = n + p
            }
        }
        p = p + 1
    }
    if prime[2] && prime[29] && !prime[30] {
        check world.out.write("sieve ok\n")
    }
}
