fn expr(a: i32, b: i32, c: i32, d: i32) -> i32 {
    return (a + b) * (c - d)
}

fn sum4(a: i32, b: i32, c: i32, d: i32) -> i32 {
    return a + b + (c + d)
}

pub fn main(world: World) -> Void raises {
    if expr(1, 3, 9, 3) == 24 && sum4(6, 6, 6, 6) == 24 {
        check world.out.write("24 game ok\n")
    }
}
