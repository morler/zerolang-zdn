fn bits(n: u32) -> u32 {
    var value: u32 = n
    var count: u32 = 0
    while value > 0 {
        count = count + 1
        value = value / 2
    }
    return count
}

pub fn main(world: World) -> Void raises {
    if bits(1024) == 11 {
        check world.out.write("binary digits ok\n")
    }
}
