fn firstRun(text: Span<u8>) -> usize {
    if std.mem.len(text) == 0 {
        return 0
    }
    var i: usize = 1
    while i < std.mem.len(text) {
        if text[i] != text[0] {
            return i
        }
        i = i + 1
    }
    return std.mem.len(text)
}

pub fn main(world: World) -> Void raises {
    if firstRun(std.mem.span("aaabb")) == 3 {
        check world.out.write("run length ok\n")
    }
}
