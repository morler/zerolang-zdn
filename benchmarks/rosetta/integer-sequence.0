fn square(n: u32) -> u32 {
    return n * n
}

pub fn main(world: World) -> Void raises {
    var values: [8]u32 = [0_u32; 8]
    var i: usize = 0
    while i < 8 {
        values[i] = square(i as u32)
        i = i + 1
    }
    if values[0] == 0 && values[3] == 9 && (values[5] == 25 && values[7] == 49) {
        check world.out.write("integer sequence ok\n")
    }
}
