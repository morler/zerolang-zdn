fn eval(op: u8, left: i32, right: i32) -> i32 {
    if op == 43 {
        return left + right
    }
    if op == 42 {
        return left * right
    }
    return 0
}

pub fn main(world: World) -> Void raises {
    if eval(42, 6, 7) == 42 {
        check world.out.write("ast interpreter ok\n")
    }
}
