fn b64(c: u8) -> u8 {
    if c >= 65 && c <= 90 {
        return c - 65
    }
    if c >= 97 && c <= 122 {
        return c - 97 + 26
    }
    if c >= 48 && c <= 57 {
        return c - 48 + 52
    }
    if c == 43 {
        return 62
    }
    return 63
}

fn firstByte(a: u8, b: u8) -> u8 {
    return b64(a) * 4 + b64(b) / 16
}

pub fn main(world: World) -> Void raises {
    if firstByte(84, 87) == 77 {
        check world.out.write("base64 decode ok\n")
    }
}
