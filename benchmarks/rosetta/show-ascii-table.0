pub fn main(world: World) -> Void raises {
    var table: [95]u8 = [0_u8; 95]
    var code: u8 = 32
    var i: usize = 0
    while code <= 126 {
        table[i] = code
        code = code + 1
        i = i + 1
    }
    if table[0] == 32 && table[33] == 65 && (table[58] == 90 && table[94] == 126) {
        check world.out.write("ascii table ok\n")
    }
}
