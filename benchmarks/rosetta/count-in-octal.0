fn octalDigits(value: u32) -> u32 {
    var n: u32 = value
    var count: u32 = 0
    while n > 0 {
        count = count + 1
        n = n / 8
    }
    return count
}

pub fn main(world: World) -> Void raises {
    if octalDigits(511) == 3 {
        check world.out.write("count in octal ok\n")
    }
}
