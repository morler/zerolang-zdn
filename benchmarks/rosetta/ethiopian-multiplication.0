fn eth(a0: i32, b0: i32) -> i32 {
    var a: i32 = a0
    var b: i32 = b0
    var total: i32 = 0
    while a > 0 {
        if a % 2 == 1 {
            total = total + b
        }
        a = a / 2
        b = b * 2
    }
    return total
}

pub fn main(world: World) -> Void raises {
    if eth(17, 34) == 578 {
        check world.out.write("ethiopian multiplication ok\n")
    }
}
