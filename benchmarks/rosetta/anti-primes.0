fn antiPrime(n: u32) -> Bool {
    let target: u32 = std.math.divisorCountU32(n)
    var value: u32 = 1
    while value < n {
        if std.math.divisorCountU32(value) >= target {
            return false
        }
        value = value + 1
    }
    return true
}

pub fn main(world: World) -> Void raises {
    if antiPrime(12) {
        check world.out.write("anti prime ok\n")
    }
}
