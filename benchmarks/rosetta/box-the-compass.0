fn quadrant(degrees: u16) -> u8 {
    if degrees < 90 {
        return 0
    }
    if degrees < 180 {
        return 1
    }
    if degrees < 270 {
        return 2
    }
    return 3
}

pub fn main(world: World) -> Void raises {
    if quadrant(45) == 0 && quadrant(225) == 2 {
        check world.out.write("compass ok\n")
    }
}
