fn egyptianProduct(a: u32, b: u32) -> u32 {
    var x: u32 = a
    var y: u32 = b
    var total: u32 = 0
    while y > 0 {
        if y % 2 == 1 {
            total = total + x
        }
        x = x * 2
        y = y / 2
    }
    return total
}

pub fn main(world: World) -> Void raises {
    if egyptianProduct(17, 23) == 391 {
        check world.out.write("egyptian division ok\n")
    }
}
