fn rotate3 u32 n u32
  ret + (* (% n 100) 10) (/ n 100)

fn circularPrime3 Bool n u32
  let a rotate3 n
  let b rotate3 a
  ret && (&& (std.math.isPrimeU32 n) (std.math.isPrimeU32 a)) (std.math.isPrimeU32 b)

pub fn main Void world World !
  if circularPrime3 197
    check world.out.write "circular prime ok\n"
