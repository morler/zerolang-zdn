use std.codec

pub fn main(world: World) -> Void raises {
    var i: i32 = 0
    var len: usize = 0
    var checksum: u32 = 0
    while i < 50000 {
        len = std.codec.encodedVarintLen(300)
        checksum = std.codec.crc32("zero benchmark payload")
        i = i + 1
    }
    if len == 2 && checksum > 0 {
        check world.out.write("codec\n")
    }
}
